#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEServer.h>
#include <BLE2902.h>
#include "src/STSServoDriver.h"

#define SERVICE_UUID      "4fafc201-1fb5-459e-8fcc-c5c9c331914b"
#define COMMAND_CHAR_UUID "12345678-1234-1234-1234-1234567890ac"
#define DATA_CHAR_UUID    "12345678-1234-1234-1234-1234567890ad"

#define RXD 5
#define TXD 4

#define SERVO_ID_1 3
#define SERVO_ID_2 1


const int sensorPin1 = 0;
const int ledPin1 = 10;

// Configurable values within app
int moveAmount = 8000;
int slouchThreshold1 = 425;

// non-configurable declarations
unsigned long slouchStartTime1 = 0;
unsigned long lastBlinkTime1 = 0;

bool slouching1 = false;
bool ledState1 = false;
bool motorActuated = false;

String currentMode = "ACTIVE"; // start off in active mode

BLECharacteristic *pCommandCharacteristic; // phone->ESP32
BLECharacteristic *pDataCharacteristic; // ESP32->phone

String lastStatusMsg = "";

STSServoDriver servos; 

// Brace mode movement: Move to predefined "good posture" position
void moveToBracePosition() {
  Serial.println("Moving motors to BRACE position");
  servos.setTargetPosition(SERVO_ID_1, -moveAmount, 500);
  delay(10);
  servos.setTargetPosition(SERVO_ID_2, moveAmount, 500);
  motorActuated = true;
}

// Releases motors from the brace mode -> sends them back to unraveled position
void releaseBracePosition() {
  Serial.println("Releasing motors from BRACE position");
  servos.setTargetPosition(SERVO_ID_1, moveAmount, 500);
  delay(10);
  servos.setTargetPosition(SERVO_ID_2, -moveAmount, 500);
  motorActuated = false;
}

// handles changing of modes in BLE
class CommandCallbacks : public BLECharacteristicCallbacks {
  void onWrite(BLECharacteristic *pCharacteristic) {
    String value = pCharacteristic->getValue();

    Serial.print("Command received: ");
    Serial.println(value);

    if (value.indexOf("BRACE") >= 0) {
      currentMode = "BRACE";
      Serial.println("Mode changed to BRACE");

      if (!motorActuated) {
        moveToBracePosition();
      }
    }

    if (value.indexOf("ACTIVE") >= 0) {
      currentMode = "ACTIVE";
      Serial.println("Mode changed to ACTIVE");

      if (motorActuated) {
        releaseBracePosition();
      }
    }

  // Set move value from app
  if (value.indexOf("SET_MOVE_AMOUNT") >= 0) {
    int amountIndex = value.indexOf("\"amount\":");

    if (amountIndex >= 0) {
      int start = amountIndex + 9;
      int end = value.indexOf("}", start);

      String amountString = value.substring(start, end);
      int newAmount = amountString.toInt();

      if (newAmount >= 0 && newAmount <= 12000) {
        moveAmount = newAmount;

        Serial.print("Move amount changed to: ");
        Serial.println(moveAmount);
      }
    }
}

  if (value.indexOf("SET_SLOUCH_THRESHOLD") >= 0) {
        int thresholdIndex = value.indexOf("\"threshold\":");

        if (thresholdIndex >= 0) {
          int start = thresholdIndex + 12;
          int end = value.indexOf("}", start);

          String thresholdString = value.substring(start, end);
          int newThreshold = thresholdString.toInt();

          if (newThreshold >= 0 && newThreshold <= 4095) {
            slouchThreshold1 = newThreshold;

            Serial.print("Slouch threshold changed to: ");
            Serial.println(slouchThreshold1);
          }
        }
      }
  }
};

void setup() {
  Serial.begin(115200);

  pinMode(ledPin1, OUTPUT);
  digitalWrite(ledPin1, LOW);

  Serial1.begin(1000000, SERIAL_8N1, RXD, TXD);
  delay(1000);

  if (servos.init(&Serial1)) {
    Serial.println("Servo ready");
  } else {
    Serial.println("Servo not found — check wiring");
  }

  servos.setMode(0xFE, STSMode::STEP);


  // BLE setup
  Serial.println("Starting BLE work!");

  BLEDevice::init("APCV");

  BLEServer *pServer = BLEDevice::createServer();
  BLEService *pService = pServer->createService(SERVICE_UUID);

  pCommandCharacteristic = pService->createCharacteristic(
    COMMAND_CHAR_UUID,
    BLECharacteristic::PROPERTY_WRITE
  );

  pCommandCharacteristic->setCallbacks(new CommandCallbacks());

  pDataCharacteristic = pService->createCharacteristic(
    DATA_CHAR_UUID,
    BLECharacteristic::PROPERTY_READ |
    BLECharacteristic::PROPERTY_NOTIFY
  );

  pDataCharacteristic->addDescriptor(new BLE2902());

  pDataCharacteristic->setValue(
    "{\"s1\":0,\"posture\":\"GOOD_POSTURE\",\"mode\":\"ACTIVE\",\"moveAmount\":8000,\"slouchThreshold1\":425}"
  );

  pService->start();

  BLEAdvertising *pAdvertising = BLEDevice::getAdvertising();
  pAdvertising->addServiceUUID(SERVICE_UUID);
  pAdvertising->setScanResponse(true);
  pAdvertising->setMinPreferred(0x06);
  pAdvertising->setMaxPreferred(0x12);

  BLEDevice::startAdvertising();

  Serial.println("BLE ready. Phone can connect now.");
}

void loop() {
  int value1 = analogRead(sensorPin1); // read sensor value
  float voltage1 = value1 * 3.3 / 4095.0;

  Serial.print("Sensor 1 Raw: ");
  Serial.print(value1);
  Serial.print("   Voltage: ");
  Serial.println(voltage1);

  String status1;

  // Good Posture: Value is below set threshold
  if (value1 < slouchThreshold1) {
    Serial.println("Sensor 1: Good Posture");

    digitalWrite(ledPin1, LOW);

    slouching1 = false;
    ledState1 = false;
    slouchStartTime1 = 0;

    if (motorActuated && currentMode == "ACTIVE") {
      releaseBracePosition();
    }

    if (currentMode == "BRACE") {
      status1 = "BRACED";
    } else {
      status1 = "GOOD_POSTURE";
    }
  } else { // else Slouching: Value < Threshold
    Serial.println("Sensor 1: Slouch Detected!");

    if (!slouching1) {
      slouching1 = true;
      slouchStartTime1 = millis();
    }

    unsigned long slouchElapsed1 = (millis() - slouchStartTime1) / 1000;

    Serial.print("Sensor 1 Slouch Time: ");
    Serial.print(slouchElapsed1);
    Serial.println(" seconds");

    if (currentMode == "BRACE") {
      digitalWrite(ledPin1, HIGH);

      if (!motorActuated) {
        moveToBracePosition();
      }

      status1 = "BRACED";
    } else if (slouchElapsed1 >= 30) {
      Serial.println("ACTIVE mode: slouch over 30s, motors actuating");

      ledState1 = true;
      digitalWrite(ledPin1, HIGH);

      if (!motorActuated) {
        moveToBracePosition();
      }

      status1 = "ACTUATING";
    } else {
      status1 = "SLOUCHING";

      if (millis() - lastBlinkTime1 >= 500) {
        lastBlinkTime1 = millis();
        ledState1 = !ledState1;
        digitalWrite(ledPin1, ledState1);
      }
    }
  }

  // send status message
  String statusMsg = "{\"s1\":" + String(value1) +
                     ",\"posture\":\"" + status1 +
                     "\",\"mode\":\"" + currentMode +
                     "\",\"moveAmount\":" + String(moveAmount) +
                     ",\"slouchThreshold1\":" + String(slouchThreshold1) + "}";

  if (statusMsg != lastStatusMsg) {
    Serial.print("Sending BLE update: ");
    Serial.println(statusMsg);

    pDataCharacteristic->setValue(statusMsg.c_str());
    pDataCharacteristic->notify();

    lastStatusMsg = statusMsg;
  }

  Serial.println("----------------------------");
  delay(100);
}
