const int sensorPin1 = 1;      //first stretch sensor ADC pin
const int sensorPin2 = 0;      //second stretch sensor ADC pin

const int ledPin1 = 2;         //LED for sensor 1
const int ledPin2 = 10;        //LED for sensor 2

const int slouchThreshold1 = 640;
const int slouchThreshold2 = 630;

//timing variables for sensors
unsigned long slouchStartTime1 = 0; //gives us the time we started slouching
unsigned long slouchStartTime2 = 0;
unsigned long lastBlinkTime1 = 0; //for blink speed control
unsigned long lastBlinkTime2 = 0;

bool slouching1 = false;
bool slouching2 = false;
bool ledState1 = false;
bool ledState2 = false;

void setup() {
  Serial.begin(115200);

  pinMode(ledPin1, OUTPUT);
  pinMode(ledPin2, OUTPUT);

  digitalWrite(ledPin1, LOW);
  digitalWrite(ledPin2, LOW);
}

void loop() {
  //SENSOR 1
  int value1 = analogRead(sensorPin1);
  float voltage1 = value1 * 3.3 / 4095.0;

  Serial.print("Sensor 1 Raw: ");
  Serial.print(value1);
  Serial.print("   Voltage: ");
  Serial.println(voltage1);

  if (value1 < slouchThreshold1) {
    Serial.println("Sensor 1: Good Posture");
    digitalWrite(ledPin1, LOW); //LED should be OFF

    slouching1 = false; //not slouching, LED off, timer=0
    ledState1 = false;
    slouchStartTime1 = 0;
  } 
  else {
    Serial.println("Sensor 1: Slouch Detected!");

    if (!slouching1) { 
      slouching1 = true;
      slouchStartTime1 = millis();
    }

    unsigned long slouchElapsed1 = (millis() - slouchStartTime1) / 1000;
    Serial.print("Sensor 1 Slouch Time: ");
    Serial.print(slouchElapsed1);
    Serial.println(" seconds");

    if (slouchElapsed1 >= 30) {
      Serial.println("Sensor 1: Slouch over 30s"); //more than 30s, correction will start
      ledState1 = true;
      digitalWrite(ledPin1, HIGH);
    }
    else {
      if (millis() - lastBlinkTime1 >= 500) {
        lastBlinkTime1 = millis();
        ledState1 = !ledState1;
        digitalWrite(ledPin1, ledState1);
      }
    }
  }

  //SENSOR 2
  int value2 = analogRead(sensorPin2);
  float voltage2 = value2 * 3.3 / 4095.0;

  Serial.print("Sensor 2 Raw: ");
  Serial.print(value2);
  Serial.print("   Voltage: ");
  Serial.println(voltage2);

  if (value2 < slouchThreshold2) {
    Serial.println("Sensor 2: Good Posture");
    digitalWrite(ledPin2, LOW);

    slouching2 = false;
    ledState2 = false;
    slouchStartTime2 = 0;
  } 
  else {
    Serial.println("Sensor 2: Slouch Detected!");

    if (!slouching2) {
      slouching2 = true;
      slouchStartTime2 = millis();
    }

    unsigned long slouchElapsed2 = (millis() - slouchStartTime2) / 1000;
    Serial.print("Sensor 2 Slouch Time: ");
    Serial.print(slouchElapsed2);
    Serial.println(" seconds");

    if (slouchElapsed2 >= 30) {  
      Serial.println("Sensor 2: Slouch over 30s");
      ledState2 = true;
      digitalWrite(ledPin2, HIGH);
    }
    else {
      if (millis() - lastBlinkTime2 >= 500) {
        lastBlinkTime2 = millis();
        ledState2 = !ledState2;
        digitalWrite(ledPin2, ledState2);
      }
    }
  }

  Serial.println("----------------------------");
  delay(100);
}
